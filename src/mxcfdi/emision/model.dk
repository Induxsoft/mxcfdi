#include "dkli.dkh"
#!
module "Emisión de comprobantes fiscales por tipo de operación. :emision"
{
    @table_name = "ut_cfd"
    @keyfield = "sys_pk"

    getJsonData::name
    {
        file_path = path.concat(@json_path,str(name))
        if file.exists(file_path){ return from.json(file.rtext(file_path)) }
        return @null
    }

    getEntity::&db,&params
    {
        if @@(params,"$_entity_id") == "ventas" { return dbr.rec(db,ftext(@qry_read_venta),params) }
        else if @@(params,"$_entity_id") == "cxc" { return dbr.rec(db,ftext(@qry_read_dcxc),params) }

        return record.create()
    }

    getCliente::&db,&params
    {
        tname = ""
        
        if @@(params,"$_entity_id") == "ventas" { tname = "venta" }
        else if @@(params,"$_entity_id") == "cxc" { tname = "dcxc" }

        ref p = dbr.rec(db,ftext("SELECT icliente FROM #<tname> WHERE sys_pk = @doc"),params)
        
        return dbr.rec(db,@qry_get_receptor,p)
    }

    getEmisorFactudesk::&data
    {
        new h{@"content-type":"application/json; charset=utf-8"}

        res=http.request(@svc_fdsk_get_emisor,"POST",h,to.json(data))
        ref result=from.json(res)

        if not(@@(result,"$success")){do rise_error(500,@@(result,"$message"))}

        return @@(result,"&data")
    }

    getEmisor::&db,&params,&cliente
    {
        ref emisor = @null

        if @@(params,"$_entity_id") == "ventas" {
            query = "
            SELECT
                cfg.nic,
                cfg.cti,
                cfg.pwd
            FROM venta AS vnt
                INNER JOIN cconsumo AS cc ON vnt.icconsumo = cc.sys_pk
                INNER JOIN mxcfdi_emisor AS cfg ON cc.cfdi_emisor = cfg.sys_pk
            WHERE vnt.sys_pk = @doc
            "
            ref emisor:dbr.rec(db,query,params)
        }
        
        if isnull(emisor) && @@(cliente,"#cfdi_emisor") > 0 { ref emisor:dbr.rec(db,"SELECT nic, cti, pwd FROM mxcfdi_emisor WHERE sys_pk = @cfdi_emisor",cliente) }
        
        if isnull(emisor) { ref emisor:dbr.rec(db,"SELECT nic, cti, pwd FROM mxcfdi_emisor WHERE predet LIMIT 1",@null) }

        if isnull(emisor) { do rise_error(511,"No se encontró datos del emisor, necesita configurar un emisor en el módulo de `Facturacón electrónica`.") }
        else
        {
            ref result=getEmisorFactudesk(emisor)
            
            //codigo postal de emisor
            using emisor
            {
                @"nombre":@@(result,"$razon_social")
                @"rfc": @@(result,"$rfc")
                @"reg_fiscal": @@(result,"$reg_fiscal")
                @"domicilios*":@@(result,"&domicilios")
                @"certificados*":@@(result,"&certificados")
            }
        }

        return emisor
    }

    getFilUsoCfdi::&db,&params,&data
    {
        ref uso_cfdi = emision.getJsonData(@sat_uso_cfdi)
        ref cliente = emision.getCliente(db,params)
        ref filtered = list.create()

        pMoral = (length(@@(cliente,"$rfc")) == 12)
        pFisica = (length(@@(cliente,"$rfc")) == 13)

        for i = 0; i < list.count(uso_cfdi); i+1
        {
            ref uso = list.obj(uso_cfdi,i)
            add = @false

            if pMoral && parse.bool(@@(uso,"$pmoral")) { add = @true }
            if pFisica && parse.bool(@@(uso,"$pfisica")) { add = @true }

            if add { do list.add(filtered,uso) }
        }

        return filtered
    }

    getFilRegFiscal::&db,&params,&data
    {
        ref reg_fiscal = emision.getJsonData(@sat_regimen_fiscal)
        ref cliente = emision.getCliente(db,params)
        ref filtered = list.create()

        pMoral = (length(@@(cliente,"$rfc")) == 12)
        pFisica = (length(@@(cliente,"$rfc")) == 13)

        for i = 0; i < list.count(reg_fiscal); i+1
        {
            ref reg = list.obj(reg_fiscal,i)
            add = @false

            if pMoral && parse.bool(@@(reg,"$moral")) { add = @true }
            if pFisica && parse.bool(@@(reg,"$fisica")) { add = @true }

            if add { do list.add(filtered,reg) }
        }

        return filtered
    }

    prepareView::&db,&params,&data
    {
        //#region prepareView()
        namespace "emision"

        _view = trim(@@(params,"$_view"))

        data<"entity*"> : getEntity(db,params)
        data<"cliente*"> : getCliente(db,params)

        if containsword(_view,"factura,devolucion,nota-cargo,cobro,bonificacion")
        {
            
            if _view == "cobro" { data<"doctosrel*"> : getDoctoRelacionado(db,@@(params,"#doc")) }

            using data
            {
                @"list_forma_pago*": getJsonData(@sat_forma_pago)
                @"list_metodo_pago*": getJsonData(@sat_metodo_pago)
                @"list_uso_cfdi*": getFilUsoCfdi(db,params,data)
                @"list_reg_fiscal*": getFilRegFiscal(db,params,data)
                @"list_exportacion*": getJsonData(@sat_exportacion)
                @"list_tipo_relacion*": getJsonData(@sat_tipo_relacion)
                @"list_objeto_imp*": getJsonData(@sat_objeto_imp)
            }
        }
        else if _view == "cancelar-cfdi"
        {
            data<"list_motivo*"> : getJsonData(@sat_motivo_cancelacion)
        }
    }

    evaluateFilters::&db,&params
    {
        tname = ""
        show_tab = "ingresos"
        fil_doctype = @@(params,"#fil_doctype")
        mxcfdi_nventa = parse.bool(dbr.vars.get(db,"mxcfdi_nventa"))
        if trim(@@(params,"$_show")) == "egresos" { show_tab = "egresos" }
        if trim(@@(params,"$_show")) == "pagos" { show_tab = "pagos" }

        //#region Set Default Filters
        params<"_show"> : show_tab
        if show_tab == "ingresos" && not(between(fil_doctype,1,10)) && not(mxcfdi_nventa) { fil_doctype = 1 }
        if show_tab == "egresos" && not(between(fil_doctype,11,20)) && not(mxcfdi_nventa) { fil_doctype = 11 }
        if show_tab == "ingresos" && not(between(fil_doctype,1,10)) && mxcfdi_nventa { fil_doctype = 2 }
        if show_tab == "egresos" && not(between(fil_doctype,11,20)) && mxcfdi_nventa { fil_doctype = 12 }
        if show_tab == "pagos" && not(between(fil_doctype,21,30)) { fil_doctype = 21 }
        params<"fil_doctype"> : fil_doctype
        if not(field.exist(params,"fil_timbrados")){ params<"fil_timbrados"> : @true }
        if not(field.exist(params,"fil_fdr_field")){ params<"fil_fdr_field"> : 1 }
        // fdr_init
        if not(field.exist(params,"fdr_mode")){ params<"fdr_mode"> : "month" }
        // [month]
        if not(field.exist(params,"fdr_year")){ params<"fdr_year"> : @curr_year }
        if not(field.exist(params,"fdr_month")){ params<"fdr_month"> : @curr_month }
        // [lastdays]
        if not(field.exist(params,"fdr_range")){ params<"fdr_range"> : 30 }
        // [range]
        if not(field.exist(params,"fdr_from")){ params<"fdr_from"> : "" }
        if not(field.exist(params,"fdr_to")){ params<"fdr_to"> : "" }
        //#endregion

        selects = ""
        joins = ""
        conditions = ""

        //#region Define Query
        switch fil_doctype
        {
            case 1 //Facturas
            {
                @list_query = @qry_list_venta
                tname = "vnt"

                selects = ",IFNULL(cfd.uf_foliosat,'') AS uf_foliosat"
                joins = "LEFT JOIN ut_cfd AS cfd ON vnt.sys_pk = cfd.uf_iventa"
                conditions = "
                    AND vnt.documento = #<@cFactura>
                    AND IF(IFNULL(@fil_timbrados,0), (IFNULL(cfd.sys_pk,0) > 0), NOT (IFNULL(cfd.sys_pk,0) > 0))
                "
                break
            }
            case 2 //Cargos
            {
                @list_query = @qry_list_dcxc
                tname = "cxc"

                selects = ",IFNULL(cfd.uf_foliosat,'') AS uf_foliosat"
                joins = "LEFT JOIN ut_cfd AS cfd ON cxc.sys_pk = cfd.uf_idcxc"
                conditions = "
                    AND cxc.documento IN (#<@cFactura>,#<@cNotaCargo>)
                    AND IFNULL(cxc.debe,0) > 0
                    AND cxc.iventa IS NULL
                    AND IF(IFNULL(@fil_timbrados,0), (IFNULL(cfd.sys_pk,0) > 0), NOT (IFNULL(cfd.sys_pk,0) > 0))
                "
                break
            }
            case 11 //Devoluciones
            {
                @list_query = @qry_list_venta
                tname = "vnt"

                selects = ",IFNULL(cfd.uf_foliosat,'') AS uf_foliosat"
                joins = "LEFT JOIN ut_cfd AS cfd ON vnt.sys_pk = cfd.uf_iventa"
                conditions = "
                    AND vnt.documento = #<@cNotaCredito>
                    AND IF(IFNULL(@fil_timbrados,0), (IFNULL(cfd.sys_pk,0) > 0), NOT (IFNULL(cfd.sys_pk,0) > 0))
                "
                break
            }
            case 12 //Bonificaciones
            {
                @list_query = @qry_list_dcxc
                tname = "cxc"

                selects = ",IFNULL(cfd.uf_foliosat,'') AS uf_foliosat"
                joins = "LEFT JOIN ut_cfd AS cfd ON cxc.sys_pk = cfd.uf_idcxc"
                conditions = "
                    AND IFNULL(cxc.haber,0) > 0
                    AND IFNULL(cxc.xaplicar,0) = 0
                    AND cxc.iventa IS NULL
                    AND IF(IFNULL(@fil_timbrados,0), (IFNULL(cfd.sys_pk,0) > 0), NOT (IFNULL(cfd.sys_pk,0) > 0))
                "
                break
            }
            case 21 //Cobros
            {
                @list_query = @qry_list_dcxc
                tname = "cxc"

                selects = ",IFNULL(cfd.uf_foliosat,'') AS uf_foliosat"
                joins = "LEFT JOIN ut_cfd AS cfd ON cxc.sys_pk = cfd.uf_idcxc"
                conditions = "
                    AND IFNULL(cxc.haber,0) > 0
                    AND IFNULL(cxc.xaplicar,0) = 0
                    AND (IFNULL(cxc.imovcuenta,0) > 0 OR IFNULL(cxc.imovcaja,0) > 0)
                    AND IF(IFNULL(@fil_timbrados,0), (IFNULL(cfd.sys_pk,0) > 0), NOT (IFNULL(cfd.sys_pk,0) > 0))
                "
                break
            }
        }
        //#endregion

        //#region filter-date-range
        new vnt_date_fields
        {
            @"1": "vnt.fecha" // Emisión
            @"2": "vnt.vencimiento" // Vencimiento
        }
        new cxc_date_fields
        {
            @"1": "cxc.fecha" // Emisión
            @"2": "cxc.aplicacion" // Vencimiento
        }
        fdr_field = ""
        if tname == "vnt" { fdr_field = @@(vnt_date_fields,str(@@(params,"#fil_fdr_field"))) }
        if tname == "cxc" { fdr_field = @@(cxc_date_fields,str(@@(params,"#fil_fdr_field"))) }

        switch @@(params,"$fdr_mode")
        {
            case "month"
            {
                curr_ndt = ndatetime.now()
                curr_year = ndatetime.year(curr_ndt)
                curr_month = ndatetime.month(curr_ndt)
                curr_day = ndatetime.day(curr_ndt)

                if not(field.exist(params,"fdr_year")) { params<"fdr_year"> : curr_year }
                if not(field.exist(params,"fdr_month")) { params<"fdr_month"> : curr_month }

                conditions = conditions + " AND YEAR(#<fdr_field>) = @fdr_year AND MONTH(#<fdr_field>) = @fdr_month"
                break
            }
            case "lastdays"
            {
                if not(field.exist(params,"fdr_range")) { params<"fdr_range"> : 30 } // Últimos 30 días

                conditions = conditions + " AND DATE(#<fdr_field>) BETWEEN ADDDATE(DATE(NOW()), INTERVAL -@fdr_range DAY) AND DATE(NOW())"
                break
            }
            case "range"
            {
                if not(field.exist(params,"fdr_from"))
                {
                    curr_ndt = ndatetime.now()
                    subt_ndt = ndatetime.add(curr_ndt, -30, "d")
                    ult_30_days = ndatetime.tostr(subt_ndt, "yyyy-MM-dd")

                    params<"fdr_from"> : ult_30_days
                }
                if not(field.exist(params,"fdr_to")) { params<"fdr_to"> : hoy("yyyy-MM-dd") }

                if trim(@@(params,"$fdr_from")) != "" && trim(@@(params,"$fdr_to")) != ""
                {
                    conditions = conditions + " AND DATE(#<fdr_field>) BETWEEN @fdr_from AND @fdr_to"
                }
                else if trim(@@(params,"$fdr_from")) != "" && trim(@@(params,"$fdr_to")) == ""
                {
                    conditions = conditions + " AND DATE(#<fdr_field>) >= @fdr_from"
                }
                else if trim(@@(params,"$fdr_from")) == "" && trim(@@(params,"$fdr_to")) != ""
                {
                    conditions = conditions + " AND DATE(#<fdr_field>) <= @fdr_to"
                }

                break
            }
        }
        //#endregion

        if trim(@@(params,"$fil_text")) != ""
        {
            conditions = "
            AND (
                #<tname>.referencia LIKE CONCAT('%',@fil_text,'%')
                OR cte.nombre LIKE CONCAT('%',@fil_text,'%')
            )
            "
        }

        conditions = ftext(conditions)
        @list_query = ftext(@list_query)
    }

    list::&db,&params
    {
        //#region list()
        do dbr.apps.action.grant("GX10")

        do emision.evaluateFilters(db,params)
        new data
        {
            @"data*": entity.list(db,params)
            @"itemactions*": dbr.apps.itemactions(db,"DET084","action","",0)
            @"itemreports*": dbr.apps.itemactions(db,"DET084","report","",0)
            @"mxcfdi_nventa": parse.bool(dbr.vars.get(db,"mxcfdi_nventa"))
        }
        return data

        exception
        {
            do errordet(@false)
            code = last_error_code()
            error = last_error()
            do dbr.apps.action.log()
            do rise_error(code,error)
        }
    }

    read::&db,&params
    {
        //#region read()
        do dbr.apps.action.grant("GX10")

        new data {}
        do emision.prepareView(db,params,data)
        return data

        exception
        {
            do errordet(@false)
            code = last_error_code()
            error = last_error()
            do dbr.apps.action.log()
            do rise_error(code,error)
        }
    }

    save::&db,&params,&data
    {
        //#region save()
        namespace "emision"
        
        @use_transaction = @false

        if not(field.exist(params,"doc")) { params<"doc"> : @@(data,"#doc") }
        
        ref documento = getEntity(db,params)
        ref cliente = getCliente(db,params)
        ref emisor = getEmisor(db,params,cliente)

        rfc_emisor = toupper(@@(emisor,"$rfc"))
        cfdi_id = md5(@@(params,"$_entity_id")+@@(params,"$_view")+@@(documento,"$referencia"))

        using data
        {
            @"documento*": documento
            @"emisor*": emisor
            @"cliente*": cliente
        }

        do dbr.apps.action.pre(actionCode(params))
        do dbr.begin(db)
        
        comprobante = generarCFDI(db,params,data)
        
        ref response = sellarYTimbrar(emisor,comprobante)
        do saveResponse(db,response,comprobante,rfc_emisor,cfdi_id)
        do aplicarFactura(db,params,response)

        do dbr.apps.action.pos(response)
        do dbr.commit(db)
        do dbr.apps.action.ext(response)
        
        // response<"data/url_redir"> : ifstr(field.exist(params,"---from_url_e"), url_dcode(@@(params,"$---from_url_e")), @CFD_EMISION)
        return response

        exception
        {
            do field.remove(data,"documento")
            do field.remove(data,"emisor")
            do field.remove(data,"cliente")
            do catch(db,params,data)
        }
    }

    delete::&db,&params
    {
        do rise_error(500,"Acción no implementada")
    }

    actionCode::&params
    {
        //#region actionCode()
        _view = @@(params,"$_view")

        switch @@(params,"$_entity_id")
        {
            case "ventas"
            {
                if _view == "factura" { return "GX21" }
                if _view == "devolucion" { return "GX22" }
                break
            }
            case "cxc"
            {
                if _view == "nota-cargo" { return "GX31" }
                if _view == "cobro" { return "GX32" }
                if _view == "bonificacion" { return "GX33" }
                break
            }
        }

        return ""
    }

    tipoComprobante::&params
    {
        //#region tipoComprobante()
        _view = @@(params,"$_view")

        switch @@(params,"$_entity_id")
        {
            case "ventas"
            {
                if _view == "factura" { return "I" }
                if _view == "devolucion" { return "E" }
                break
            }
            case "cxc"
            {
                if _view == "nota-cargo" { return "I" }
                if _view == "cobro" { return "P" }
                if _view == "bonificacion" { return "E" }
                break
            }
        }

        return ""
    }
    getDomicilioEmisor::&emisor
    {
        ref domicilio=cfdi.find(@@(emisor,"&domicilios"),"#fiscal",1)
        if isnull(domicilio)
        {
            do rise_error(500,"No se encontró el domicilio fiscal del emisor")
        }
        return domicilio
    }
    generarCFDI::&db,&params,&data
    {
        //#region generarCFDI()
        namespace "emision"

        ref documento = field.obj(data,"documento")
        ref emisor = field.obj(data,"emisor")

        ref domicilio=getDomicilioEmisor(emisor)
        ref cliente = field.obj(data,"cliente")

        program_path = "mxcfdi/emision"
        program_name = "cfdi40.dkl"
        
        new cfdi
        {
            @"Serie": field.dstr(documento,"serie","")
            @"Folio": field.dstr(documento,"folio","")
            @"Fecha": hoy("yyyy-MM-ddTHH:mm:ss")
            @"MetodoPago": field.dstr(data,"metodo_pago","PPD")
            @"FormaPago": field.dstr(data,"forma_pago","99")
            @"CondicionesDePago": field.dstr(data,"cond_pago","")
            @"TipoDeComprobante": tipoComprobante(params)
            @"Moneda": field.str(documento,"cdivisa")
            @"TipoCambio": field.dnum(documento,"tipocambio",1)
            @"LugarExpedicion": @@(domicilio,"$codpos")
            @"Exportacion": field.dstr(data,"exportacion","01")
            @"SubTotal": 0.00 //field.dnum(documento,"subtotal",0)
            @"Descuento": 0.00 //field.dnum(documento,"descuentos",0)
            @"Total": 0.00 //field.dnum(documento,"total",0)

            member @"CfdiRelacionados"
            {
                @"TipoRelacion": field.dstr(data,"tipo_relacion","")
                @"Relacionados*": from.json(field.dstr(data,"rel_uuid","[]"))
            }
            
            member @"Emisor"
            {
                @"Nombre": cfdi.SpecialChars(field.str(emisor,"nombre"))
                @"Rfc": field.str(emisor,"rfc")
                @"RegimenFiscal": field.str(emisor,"reg_fiscal")
            }

            member @"Receptor"
            {
                @"Nombre": cfdi.SpecialChars(field.str(cliente,"nombre"))
                @"DomicilioFiscalReceptor": field.str(data,"codpos")
                @"Rfc": field.str(cliente,"rfc")
                @"UsoCFDI": field.str(data,"uso_cfdi")
                @"RegimenFiscalReceptor": field.str(data,"reg_fiscal")
            }
        }

        if @@(cfdi,"$Moneda") == "MXN" { cfdi<"TipoCambio"> : 1 }
        if @@(cfdi,"$TipoDeComprobante") == "P" 
        {
            program_name = "cfdi40.pago20.dkl"
            do setComplementoP(db,data,cfdi)
        }
        else { do setConceptos(db,params,data,cfdi) }

        do setAddenda(db,cliente,cfdi,emisor)

        comprobante = to.base64(replace(runscript(path.concat(program_path,program_name),"cfdi",cfdi)," = ","="))
        return comprobante
    }

    getClaveImpuesto::descripcion
    {
        new impuestos
        {
            @"ISR": "001"
            @"IVA": "002"
            @"IEPS": "003"
        }
        return field.dstr(impuestos,toupper(trim(str(descripcion))),"")
    }

    conceptosVenta::&db,&params,&cfdi
    {
        //#region conceptosVenta()
        ref dventa = dbr.list(db,ftext(@qry_childs_venta),params)
        ref conceptos = list.create()
        ref _traslados = record.create()
        ref _retenciones = record.create()

        SubTotal = 0.00
        Descuento = 0.00
        Total = 0.00
        TotalImpuestosTrasladados = 0.00
        TotalImpuestosRetenidos = 0.00

        go foreach.lobj(value:obj) with(dventa)
        {
            ref traslados = list.create()
            for tipo = 1; tipo <= 4
            {
                /**
                * tipo 1 = IEPS
                * tipo 2 = ??
                * tipo 3 = IVA
                * tipo 4 = ??
                */
                imp_text = field.str(obj,ftext("i#<tipo>_text"))
                imp_tasa = ftext("i#<tipo>_tasa")
                imp_value = ftext("impuesto#<tipo>")

                if imp_text != "" && field.str(obj,"objetoimp") == "02"
                {
                    new traslado
                    {
                        @"Impuesto": emision.getClaveImpuesto(imp_text)
                        @"TipoFactor": ifstr(@@(obj,"#exento_iva"),"Exento","Tasa")
                        @"TasaOCuota": field.dnum(obj,imp_tasa,0)
                        @"Base": field.num(obj,"subtotal")
                        @"Importe": field.num(obj,imp_value)
                    }

                    if tipo > 2 { traslado<"Base"> : RoundTo(@@(obj,"#subtotal") + (@@(obj,"#impuesto1") + @@(obj,"#impuesto2")), 6, @AwayFromZero) }

                    gp_tras = md5(@@(traslado,"$Impuesto")+@@(traslado,"$TipoFactor")+@@(traslado,"$TasaOCuota"))
                    if not(field.exist(_traslados,gp_tras)) { _traslados<gp_tras+"*"> : record.copy(traslado,"*") }
                    else
                    {
                        _traslados<gp_tras+"/Base"> : @@(_traslados,"#"+gp_tras+"/Base") + @@(traslado,"#Base")
                        _traslados<gp_tras+"/Importe"> : @@(_traslados,"#"+gp_tras+"/Importe") + @@(traslado,"#Importe")
                    }
                    TotalImpuestosTrasladados = TotalImpuestosTrasladados + @@(traslado,"#Importe")

                    do list.add(traslados,traslado)
                }
            }

            new concepto
            {
                @"ClaveProdServ": field.str(obj,"uf_sat_proser")
                @"ClaveUnidad": field.str(obj,"uf_sat_uniproser")
                @"NoIdentificacion": field.str(obj,"codigo")
                @"Descripcion": field.str(obj,"descripcion")
                @"Unidad": field.str(obj,"unidad")
                @"ValorUnitario": field.num(obj,"precio")
                @"Cantidad": field.num(obj,"cantidad")
                @"Descuento": field.num(obj,"descuentos")
                @"Importe": field.num(obj,"subtotal")
                @"ObjetoImp": field.str(obj,"objetoimp")

                @"Traslados*": traslados
            }

            SubTotal = SubTotal + field.num(concepto,"Importe")
            Descuento = Descuento + field.num(concepto,"Descuento")

            do list.add(conceptos,concepto)
        }

        go foreach.fobj(value:tras) with(_traslados)
        {
            using tras
            {
                @"Base": RoundTo(@@(tras,"#Base"),2,@AwayFromZero)
                @"Importe": RoundTo(@@(tras,"#Importe"),2,@AwayFromZero)
            }
        }

        SubTotal = RoundTo(SubTotal,2,@AwayFromZero)
        Descuento = RoundTo(Descuento,2,@AwayFromZero)
        TotalImpuestosTrasladados = RoundTo(TotalImpuestosTrasladados,2,@AwayFromZero)
        TotalImpuestosRetenidos = RoundTo(TotalImpuestosRetenidos,2,@AwayFromZero)
        Total = RoundTo((((SubTotal - Descuento) + TotalImpuestosTrasladados) - TotalImpuestosRetenidos),2,@AwayFromZero)

        using cfdi
        {
            @"SubTotal": SubTotal
            @"Descuento": Descuento
            @"Total": Total

            @"Conceptos*": conceptos

            member @"Impuestos"
            {
                @"TotalImpuestosTrasladados": TotalImpuestosTrasladados
                @"TotalImpuestosRetenidos": TotalImpuestosRetenidos

                @"Traslados*": record.values(_traslados)
                @"Retenciones*": record.values(_retenciones)
            }
        }
    }

    conceptosCxC::&db,&data,&cfdi
    {
        //#region conceptosCxC()
        ref conceptos = list.create()
        ref _traslados = list.create()
        ref _retenciones = list.create()

        SubTotal = 0.00
        Descuento = 0.00
        Total = 0.00
        TotalImpuestosTrasladados = 0.00
        TotalImpuestosRetenidos = 0.00
        
        new concepto
        {
            @"ClaveProdServ": ifempty(field.str(data,"codigo_sat"),"01010101")
            @"ClaveUnidad": ifempty(field.str(data,"unidad_sat"),"ACT")
            // @"NoIdentificacion": field.str(data,"codigo")
            @"Descripcion": field.str(data,"documento/concepto")
            // @"Unidad": field.str(data,"unidad")
            @"ValorUnitario": field.num(data,"documento/importe")
            @"Cantidad": 1
            @"Descuento": 0
            @"Importe": field.num(data,"documento/importe")
            @"ObjetoImp": field.str(data,"objeto_imp")
        }

        if field.str(concepto,"ObjetoImp") == "02"
        {
            TasaOCuota = RoundTo((parse.num(field.str(data,"tasa_iva")) / 100),6,@AwayFromZero)
            ValorUnitario = RoundTo((field.num(concepto,"Importe") / (1+TasaOCuota)),6,@AwayFromZero)

            using concepto
            {
                @"ValorUnitario": ValorUnitario
                @"Importe": ValorUnitario
            }

            Base = ValorUnitario
            Importe = RoundTo((Base * TasaOCuota),6,@AwayFromZero)

            ref traslados = list.create()
            new traslado
            {
                @"Impuesto": "002"
                @"TipoFactor": "Tasa"
                @"TasaOCuota": FixTo(TasaOCuota,6)
                @"Base": Base
                @"Importe": Importe
            }
            if field.str(data,"tasa_iva") == "Exento" { traslado<"TipoFactor"> : "Exento" }

            do list.add(traslados,traslado)
            concepto<"Traslados*"> : traslados

            TotalImpuestosTrasladados = RoundTo(field.num(traslado,"Importe"),2,@AwayFromZero)

            ref tras = record.copy(traslado,"*")
            using tras
            {
                @"Base": RoundTo(@@(tras,"#Base"),2,@AwayFromZero)
                @"Importe": RoundTo(@@(tras,"#Importe"),2,@AwayFromZero)
            }
            do list.add(_traslados,tras)
        }
        do list.add(conceptos,concepto)

        SubTotal = RoundTo(field.num(concepto,"Importe"),2,@AwayFromZero)
        Total = RoundTo((((SubTotal - Descuento) + TotalImpuestosTrasladados) - TotalImpuestosRetenidos),2,@AwayFromZero)

        using cfdi
        {
            @"SubTotal": SubTotal
            @"Descuento": Descuento
            @"Total": Total

            @"Conceptos*": conceptos

            member @"Impuestos"
            {
                @"TotalImpuestosTrasladados": TotalImpuestosTrasladados
                @"TotalImpuestosRetenidos": TotalImpuestosRetenidos

                @"Traslados*": _traslados
                @"Retenciones*": _retenciones
            }
        }
    }

    setConceptos::&db,&params,&data,&cfdi
    {
        if @@(params,"$_entity_id") == "ventas" { do emision.conceptosVenta(db,params,cfdi) }
        if @@(params,"$_entity_id") == "cxc" { do emision.conceptosCxC(db,data,cfdi) }
    }

