    getDoctoRelacionado::&db,irecibo
    {
        new params { @"irecibo": irecibo }

        sql_facturas_aplicadas = "
        SELECT fac.referencia,fac.sys_pk idcxc,fac.iventa
        FROM aplcxc AS apl
            INNER JOIN dcxc AS fac ON apl.aplicadoa = fac.sys_pk
        WHERE apl.fk_dcxc_aplicadoa = @irecibo AND (TRIM(IFNULL(apl.uf_cfdi,''))='' OR apl.uf_cfdi='0')
        GROUP BY fac.sys_pk;
        "
        ref facturas_aplicadas = dbr.list(db,sql_facturas_aplicadas,params)
        ref relacionados = list.create()

        for i = 0; i < list.count(facturas_aplicadas)
        {
            params<"idcxc"> : field.num(list.obj(facturas_aplicadas,i),"idcxc")
            params<"iventa"> : field.num(list.obj(facturas_aplicadas,i),"iventa")

            sql_facturas_saldadas = "
            SELECT
                @parcis:=(@parcis + 1) AS NumParcialidad,
                f.debe,
                ROUND(f.debe - @rownum:=(@rownum + a.importe),2) AS ImpSaldoInsoluto,
                ROUND(a.importe,2) AS ImpPagado,
                ROUND(f.debe - @rownum + a.importe,2) AS ImpSaldoAnt,
                (SELECT uf_foliosat FROM ut_cfd WHERE uf_idcxc=@idcxc or uf_iventa =@iventa  LIMIT 1) AS IdDocumento,
                bd.serie AS Serie,
                fd.folio AS Folio,
                dv.codigo AS MonedaDR,
                f.tipocambio AS EquivalenciaDR,
                '' AS ObjetoImpDR,
                a.sys_pk AS pk_aplcxc, -- Registro de aplicación de pago
                a.fk_dcxc_aplicadoa, -- Doc del pago (Recibo)
                a.aplicadoa AS fk_aplicadoa, -- Doc al que se aplico el pago (Factura)
                IFNULL(a.uf_cfdi,'') AS uf_cfdi
            FROM (SELECT @parcis:=0) q, (SELECT @rownum:=0) r, aplcxc AS a
                INNER JOIN dcxc AS p ON a.fk_dcxc_aplicadoa = p.sys_pk
                INNER JOIN dcxc AS f ON a.aplicadoa = f.sys_pk
                LEFT JOIN foliosdocumentos AS fd ON f.ifolio = fd.sys_pk
                LEFT JOIN blockdocumentos AS bd ON fd.block = bd.sys_pk
                INNER JOIN cliente cl on f.icliente=cl.sys_pk
                INNER JOIN divisa AS dv ON cl.idivisa = dv.sys_pk
            WHERE f.sys_pk = @idcxc
            "
            ref facturas_saldadas = dbr.list(db,"SELECT * FROM ("+sql_facturas_saldadas+") AS sbqry WHERE fk_dcxc_aplicadoa=@irecibo",params)

            for j = 0; j < list.count(facturas_saldadas)
            {
                do list.add(relacionados,list.obj(facturas_saldadas,j))
            }
        }

        return relacionados
    }
    getImpuestosDR::&db,&params
    {
        do errordet(@error_det)

        ref response = emision.descargar(db,@@(params,"$uuid"),"xmlb64")
        ref comprobante = parse.xmlStr(from.base64(@@(response,"$data/content")))
        ref impuestos = cfdi.getElementByTagName(comprobante,"cfdi:Impuestos")
        ref traslados = cfdi.getElementByTagName(impuestos,"cfdi:Traslados")
        ref retenciones = cfdi.getElementByTagName(impuestos,"cfdi:Retenciones")

        ref traslados_dr = list.create()
        ref retenciones_dr = list.create()

        // code

        new ImpuestosDR
        {
            @"TrasladosDR*": traslados_dr
            @"RetencionesDR*": retenciones_dr
        }
        
        return ImpuestosDR
    }

    setDoctoRelacionado::&db,&data,&cfdi
    {
        //#region setDoctoRelacionado()
        ref doctosrel = from.json(field.dstr(data,"doctosrel","[]"))
        ref relacionados = list.create()
        ref _traslados_dr = record.create()
        ref _retenciones_dr = record.create()

        TotalTrasladosBaseIVA16 = 0.00
        TotalTrasladosImpuestoIVA16 = 0.00
        TotalTrasladosBaseIVA8 = 0.00
        TotalTrasladosImpuestoIVA8 = 0.00
        TotalTrasladosBaseIVA0 = 0.00
        TotalTrasladosImpuestoIVA0 = 0.00
        TotalTrasladosBaseIVAExento = 0.00
        MontoTotalPagos = 0.00

        Pagado = @@(data,"#documento/importe")

        for i = 0; i < list.count(doctosrel)
        {
            ref docto = list.obj(doctosrel,i)
            if field.str(docto,"IdDocumento") == "" { do rise_error(500,"Es necesario timbrar todos los documentos relacionados.") }
            ref DoctoRelacionado = record.copy(docto,"IdDocumento,Serie,Folio,MonedaDR,EquivalenciaDR,NumParcialidad,ImpSaldoAnt,ImpPagado,ImpSaldoInsoluto,ObjetoImpDR")

            if field.str(docto,"ObjetoImpDR") == "02"
            {
                ref response = emision.descargar(db,@@(docto,"$IdDocumento"),"xmlb64")
                ref comprobante = parse.xmlStr(from.base64(@@(response,"$data/content")))
                ref impuestos = cfdi.getElementByTagName(comprobante,"cfdi:Impuestos")
                ref traslados = cfdi.getElementByTagName(impuestos,"cfdi:Traslados")
                ref retenciones = cfdi.getElementByTagName(impuestos,"cfdi:Retenciones")

                ref traslados_dr = list.create()
                ref retenciones_dr = list.create()

                Proporcion = (Pagado / cfdi.attr(comprobante,"#Total"))

                for j = 0; j < list.count(cfdi.nodes(traslados))
                {
                    ref traslado = cfdi.attributes(list.obj(cfdi.nodes(traslados),j))
                    
                    BaseDR = RoundTo(Proporcion * @@(traslado,"#Base"),6,@AwayFromZero)
                    ImporteDR = RoundTo(BaseDR * @@(traslado,"#TasaOCuota"),6,@AwayFromZero)

                    new traslado_dr
                    {
                        @"ImpuestoDR": @@(traslado,"$Impuesto")
                        @"TipoFactorDR": @@(traslado,"$TipoFactor")
                        @"TasaOCuotaDR": @@(traslado,"#TasaOCuota")
                        @"BaseDR": BaseDR
                        @"ImporteDR": ImporteDR
                    }
                    
                    if field.str(traslado_dr,"ImpuestoDR") == "002" {
                    switch field.num(traslado_dr,"TasaOCuotaDR") * 100
                    {
                        case 16
                        {
                            TotalTrasladosBaseIVA16 = TotalTrasladosBaseIVA16 + @@(traslado_dr,"#BaseDR")
                            TotalTrasladosImpuestoIVA16 = TotalTrasladosImpuestoIVA16 + @@(traslado_dr,"#ImporteDR")
                            break
                        }
                        case 8
                        {
                            TotalTrasladosBaseIVA8 = TotalTrasladosBaseIVA8 + @@(traslado_dr,"#BaseDR")
                            TotalTrasladosImpuestoIVA8 = TotalTrasladosImpuestoIVA8 + @@(traslado_dr,"#ImporteDR")
                            break
                        }
                        case 0
                        {
                            if field.str(traslado_dr,"TipoFactorDR") == "Exento"
                            {
                                TotalTrasladosBaseIVAExento = TotalTrasladosBaseIVAExento + @@(traslado_dr,"#BaseDR")
                            }
                            else
                            {
                                TotalTrasladosBaseIVA0 = TotalTrasladosBaseIVA0 + @@(traslado_dr,"#BaseDR")
                                TotalTrasladosImpuestoIVA0 = TotalTrasladosImpuestoIVA0 + @@(traslado_dr,"#ImporteDR")
                            }
                            break
                        }
                    }
                    }

                    gp_tras = md5(@@(traslado_dr,"$ImpuestoDR")+@@(traslado_dr,"$TipoFactorDR")+@@(traslado_dr,"$TasaOCuotaDR"))
                    if not(field.exist(_traslados_dr,gp_tras))
                    {
                        alias = "ImpuestoDR:ImpuestoP,TipoFactorDR:TipoFactorP,TasaOCuotaDR:TasaOCuotaP,BaseDR:BaseP,ImporteDR:ImporteP"
                        _traslados_dr<gp_tras+"*"> : record.copyex(traslado_dr,@null,"*",",",alias,":")
                    }
                    else
                    {
                        _traslados_dr<gp_tras+"/BaseP"> : @@(_traslados_dr,"#"+gp_tras+"/BaseP") + @@(traslado_dr,"#BaseDR")
                        _traslados_dr<gp_tras+"/ImporteP"> : @@(_traslados_dr,"#"+gp_tras+"/ImporteP") + @@(traslado_dr,"#ImporteDR")
                    }

                    do list.add(traslados_dr,traslado_dr)
                }

                using DoctoRelacionado
                {
                    member @"ImpuestosDR"
                    {
                        @"TrasladosDR*": traslados_dr
                        @"RetencionesDR*": retenciones_dr
                    }
                }
            }

            do list.add(relacionados,DoctoRelacionado)
        }

        go foreach.fobj(value:tras_dr) with(_traslados_dr)
        {
            using tras_dr
            {
                @"BaseP": RoundTo(@@(tras_dr,"#BaseP"),2,@AwayFromZero)
                @"ImporteP": RoundTo(@@(tras_dr,"#ImporteP"),2,@AwayFromZero)
            }
        }

        using cfdi
        {
            member @"Complemento"
            {
                member @"Totales"
                {
                    @"TotalTrasladosBaseIVA16": RoundTo(TotalTrasladosBaseIVA16,2,@AwayFromZero)
                    @"TotalTrasladosImpuestoIVA16": RoundTo(TotalTrasladosImpuestoIVA16,2,@AwayFromZero)
                    @"TotalTrasladosBaseIVA8": RoundTo(TotalTrasladosBaseIVA8,2,@AwayFromZero)
                    @"TotalTrasladosImpuestoIVA8": RoundTo(TotalTrasladosImpuestoIVA8,2,@AwayFromZero)
                    @"TotalTrasladosBaseIVA0": RoundTo(TotalTrasladosBaseIVA0,2,@AwayFromZero)
                    @"TotalTrasladosImpuestoIVA0": RoundTo(TotalTrasladosImpuestoIVA0,2,@AwayFromZero)
                    @"TotalTrasladosBaseIVAExento": RoundTo(TotalTrasladosBaseIVAExento,2,@AwayFromZero)
                }
                member @"Pago"
                {
                    @"Relacionados*": relacionados
                    member @"ImpuestosP"
                    {
                        @"TrasladosP*": record.values(_traslados_dr)
                        @"RetencionesP*": record.values(_retenciones_dr)
                    }
                }
            }
        }
    }

    setComplementoP::&db,&data,&cfdi
    {
        //#region setComplementoP()
        // do rise_error(0,"Pendiente por implementar...")
        ref documento = field.obj(data,"documento")

        using cfdi
        {
            member @"Complemento"
            {
                member @"Totales"
                {
                    @"MontoTotalPagos": RoundTo(field.num(documento,"importe"),2,@AwayFromZero)
                    // ...
                }
                member @"Pago"
                {
                    @"FechaPago": hoy("yyyy-MM-ddTHH:mm:ss")
                    @"MonedaP": field.str(documento,"cdivisa")
                    @"TipoCambioP": field.num(documento,"tipocambio")
                    @"Monto": RoundTo(field.num(documento,"importe"),2,@AwayFromZero)
                    @"FormaDePagoP": field.str(data,"forma_pago")
                    @"NumOperacion": field.str(data,"no_operacion")
                }
            }
        }
        if @@(cfdi,"$Complemento/Pago/MonedaP") == "MXN" { cfdi<"Complemento/Pago/TipoCambioP"> : 1 }

        do emision.setDoctoRelacionado(db,data,cfdi)
        // do rise_error(0,to.json(cfdi))
    }

    setAddenda::&db,&cliente,&cfdi,&emisor
    {
        //#region setAddenda()
        if not(@@(cliente,"#uf_addenda")) { return }

        ref dir_receptor = dbr.rec(db,@qry_dir_receptor,cliente)
        ref domicilio=getDomicilioEmisor(emisor)

        using cfdi
        {
            member @"Addenda"
            {
                member @"DirReceptor"
                {
                    @"titulo": "Dirección del receptor"
                    @"valor1": @@(dir_receptor,"$direccion")
                    @"valor2": @@(dir_receptor,"$colonia")
                    @"valor3": @@(dir_receptor,"$codpos")
                }
                member @"LugarReceptor"
                {
                    @"titulo": "Domicilio del receptor"
                    @"valor1": @@(dir_receptor,"$municipio") + ", " + @@(dir_receptor,"$estado") + ", " + @@(dir_receptor,"$pais")
                    @"valor2": ""
                    @"valor3": ""
                }
                member @"DirEmisor"
                {
                    @"titulo": "Domicilio de expedición"
                    @"valor1": @@(domicilio,"$direccion")+" "+@@(domicilio,"$colonia") //@emisor.Direccion + " " + @emisor.Colonia
                    @"valor2": @@(domicilio,"$municipio")+", "+@@(domicilio,"$estado")+", "+@@(domicilio,"$pais") //@emisor.Municipio + ", " + @emisor.Estado + ", " + @emisor.Pais
                    @"valor3": ""
                }
                member @"NumLetraTotalDocumento"
                {
                    @"titulo": "Importe con letras"
                    @"valor1": numero_en_letras(@@(cfdi,"#Total")) + "PESOS MEXICANO"
                    @"valor2": ""
                    @"valor3": ""
                }
            }
        }
    }

    sellarYTimbrar::&emisor,comprobante
    {
        //#region sellarYTimbrar()
        new header { @"Content-Type": "application/json; charset=UTF-8" }
        new payload
        {
            @"cti": field.str(emisor,"cti")
            @"pwd": field.str(emisor,"pwd")
            @"idd": ""
            @"ncer": ""
            @"nb64": @false
            @"xml": comprobante
        }
        ref response = from.json(http.request(@svc_fdsk_sellar_timbrar,"POST",header,to.json(payload)))

        return response
    }

    descargar::&db,IdDocumento,res
    {
        //#region descargar()
        ref emisor = dbr.rec(db,"SELECT nic, cti, pwd FROM mxcfdi_emisor WHERE predet LIMIT 1",@null)
        
        // new header { @"Content-Type": "application/json; charset=UTF-8" }
        new payload
        {
            @"cti": field.str(emisor,"cti") // Cuenta de timbrado
            @"pwd": field.str(emisor,"pwd") // Contraseña de la cuenta de timbrado
            @"doc": IdDocumento // UUID del CFDI o Idd
            @"tpo": "cfdi" // cfdi/cr (opcional)
            @"res": res // (Opcional) tipo de resultado deseado
        }

        ref response = from.json(http.post(@svc_fdsk_descargar,payload))
        if not(@@(response,"#success")) { do rise_error(500,@@(response,"$message")) }

        return response
    }

    aplicarFactura::&db,&params,&response
    {
        //#region aplicarFactura()
        ref comprobante = parse.xmlStr(from.base64(@@(response,"$data/xml")))
        ref emisor = cfdi.getElementByTagName(comprobante,"cfdi:Emisor")
        ref complemento = cfdi.getElementByTagName(comprobante,"cfdi:Complemento")
        ref tfd = cfdi.getElementByTagName(complemento,"tfd:TimbreFiscalDigital")

        pk_document = @@(params,"#doc")
        cfdi_uuid = cfdi.attr(tfd,"UUID")

        new ut_cfd
        {
            @"uf_xml": cfdi_uuid
            @"uf_cadenaoriginal": ""
            @"uf_sellodigital": cfdi.attr(comprobante,"Sello")
            // @"uf_iventa*": @null //PkVenta
            // @"uf_idcxc*": @null //PkRecibo
            // @"uf_aplcxc*": @null //PkAplicado
            @"uf_fechahora*": now()
            // @"uf_tipo*": @null
            // @"uf_cfdi_info": dbr.num(db,"SELECT sys_pk FROM ut_cfdinfo WHERE NOT IFNULL(sys_deleted,0) ORDER BY sys_pk DESC LIMIT 1;",@null)
            @"uf_sellodigitalsat": cfdi.attr(tfd,"SelloSAT")
            @"uf_foliosat": cfdi_uuid
            @"uf_nocertificadosat": cfdi.attr(tfd,"NoCertificadoSAT")
            @"uf_fechahoracersat": cfdi.attr(tfd,"FechaTimbrado")
            // @"uf_xmlcfdi": @@(response,"$data/xml")
            @"uf_rfc_emisor": cfdi.attr(emisor,"Rfc")
        }

        switch @@(params,"$_entity_id")
        {
            case "ventas"
            {
                using ut_cfd
                {
                    @"uf_iventa": pk_document
                    @"uf_tipo": 3
                }
                break
            }
            case "cxc"
            {
                using ut_cfd
                {
                    @"uf_idcxc": pk_document
                    @"uf_tipo": 2
                }

                if cfdi.attr(comprobante,"TipoDeComprobante") == "P"
                {
                    new p
                    {
                        @"recibo": pk_document
                        @"foliosat": cfdi_uuid
                    }
                    sql = "UPDATE aplcxc SET uf_cfdi = @foliosat WHERE fk_dcxc_aplicadoa = @recibo AND (TRIM(IFNULL(uf_cfdi,''))='' OR uf_cfdi='0');"
                    if not(dbr.execute(db,sql,p)) { do rise_error(500,"No fue posible actualizar el registro de aplicación del recibo (aplcxc).") }
                }
                break
            }
        }

        do dbr.save(db,"ut_cfd",ut_cfd)
    }

    cfdi.preview::&db,&params
    {
        //#region preview()
        namespace "emision"

        ref documento = getEntity(db,params)
        ref cliente = getCliente(db,params)
        ref emisor = getEmisor(db,params,cliente)

        new data
        {
            @"reg_fiscal": "601"
            @"codpos": @@(cliente,"$codpos")
            @"forma_pago": ""
            @"metodo_pago": ""
            @"cond_pago": ""
            @"uso_cfdi": "G03"
            @"exportacion": "01"

            @"unidad_sat": "ACT"
            @"codigo_sat": "01010101"
            @"objeto_imp": "02"
            @"tasa_iva": "16"

            @"no_operacion": ""
            @"doctosrel": "[]"

            @"documento*": documento
            @"emisor*": emisor
            @"cliente*": cliente
        }

        doctype = @@(documento,"#documento")
        view = @@(params,"$_view")
        switch @@(params,"$_entity_id")
        {
            case "ventas"
            {
                if doctype == @cFactura { view = "factura" }
                if doctype == @cNotaCredito { view = "devolucion" }
                break
            }
            case "cxc"
            {
                if doctype == @cNotaCargo { view = "nota-cargo" }
                if doctype == @cRecibo
                {
                    view = "cobro"
                    ref doctosrel = getDoctoRelacionado(db,@@(params,"#doc"))
                    
                    using data
                    {
                        @"uso_cfdi": "CP01"
                        @"forma_pago": "01"
                        @"doctosrel": to.json(doctosrel)
                    }
                }
                if doctype == @cNotaCredito { view = "bonificacion" }
                break
            }
        }
        params<"_view"> : view
        
        cfdi_id = md5(@@(params,"$_entity_id")+@@(params,"$_view")+@@(documento,"$referencia"))
        comprobante = generarCFDI(db,params,data)

        new payload
        {
            @"cti": field.str(emisor,"cti")
            @"pwd": field.str(emisor,"pwd")
            @"rfc": field.str(emisor,"rfc")
            @"tpo": "cfdi"
            @"res": "prnlnk"
            @"uuid": cfdi_id
            @"xml": from.base64(comprobante)
        }

        ref response = from.json(http.post(@svc_fdsk_preview,payload))
        if not(@@(response,"#success")) { do rise_error(500,@@(response,"$message")) }
        
        return @@(response,"&data")

        exception
        {
            do errordet(@error_det)
            do record.clear(data)
            do rise_error(last_error_code(),last_error())
        }
    }

    cfdi.sendmail::&db,&params,&data
    {
        //#region sendmail()
        namespace "emision"
        do errordet(@error_det)

        if not(field.exist(params,"doc")) { params<"doc"> : @@(data,"#doc") }
        ref cliente = getCliente(db,params)
        ref emisor = getEmisor(db,params,cliente)
        ref doc = @null

        if trim(@@(data,"$emails")) == "" { do rise_error(500,"Debe agregar al menos un correo electrónico válido.") }

        if @@(params,"$_entity_id") == "ventas" {
            ref doc:dbr.rec(db,"SELECT vnt.referencia, IFNULL(cfd.uf_foliosat,'') AS uf_foliosat FROM venta vnt LEFT JOIN ut_cfd cfd ON vnt.sys_pk = cfd.uf_iventa WHERE vnt.sys_pk = @doc",params)
        }
        else if @@(params,"$_entity_id") == "cxc" {
            ref doc:dbr.rec(db,"SELECT cxc.referencia, IFNULL(cfd.uf_foliosat,'') AS uf_foliosat FROM dcxc cxc LEFT JOIN ut_cfd cfd ON cxc.sys_pk = cfd.uf_idcxc WHERE cxc.sys_pk = @doc",params)
        }

        if isnull(doc) { do rise_error(500,"No fue posible recuperar el documento.") }
        if @@(doc,"$uf_foliosat") == "" { do rise_error(500,"El documento aun no ha sido timbrado.") }

        // new header { @"Content-Type": "application/json; charset=UTF-8" }
        new payload
        {
            @"cti": field.str(emisor,"cti") // Cuenta de timbrado.
            @"pwd": field.str(emisor,"pwd") // Contraseña de la cuenta de timbrado.
            @"to": trim(@@(data,"$emails")) // Dirección de correo del destinatario.
            @"subject": "CFDI "+@@(doc,"$referencia")+" ("+@@(params,"$_entity_id")+")" // Asunto del correo.
            @"doc": @@(doc,"$uf_foliosat") // UUID del CFDI o Idd [doc]
            @"res": "zip" // Tipo de resultado deseado.
            @"tpo": "cfdi" // Tipo de documento solicitado: cfdi-CFDI o cr-Constancia de retención
        }

        ref response = from.json(http.post(@svc_fdsk_enviar,payload))
        if not(@@(response,"#success")) { do rise_error(500,@@(response,"$message")) }
        response<"data/url_redir"> : ifstr(field.exist(params,"---from_url_e"), url_dcode(@@(params,"$---from_url_e")), @CFD_EMISION)

        return response
    }

    cfdi.cancelar::&db,&params,&data
    {
        //#region cancelar()
        namespace "emision"
        @use_transaction = @false

        if not(field.exist(params,"doc")) { params<"doc"> : @@(data,"#doc") }
        ref cliente = getCliente(db,params)
        ref emisor = getEmisor(db,params,cliente)
        ref doc = @null

        uuid_regex = "^[0-9A-Fa-f]{8}-?[0-9A-Fa-f]{4}-?[0-9A-Fa-f]{4}-?[0-9A-Fa-f]{4}-?[0-9A-Fa-f]{12}$"
        _entity_id = @@(params,"$_entity_id")
        cve_motivo = @@(data,"$motivo")
        rel_uuid = trim(@@(data,"$uuid"))

        if cve_motivo == "01" && not(Regex.IsMatch(rel_uuid,uuid_regex)) {
            do rise_error(500,"Es necesario indicar un UUID válido.\r\nDebe tener el formato 8-4-4-4-12 con caracteres hexadecimales.")
        }

        if _entity_id == "ventas" {
            sql = "
            SELECT vnt.sys_pk AS iventa, cfd.sys_pk AS icfd, vnt.referencia, IFNULL(cfd.uf_foliosat,'') AS uf_foliosat
            FROM venta vnt
                LEFT JOIN ut_cfd cfd ON vnt.sys_pk = cfd.uf_iventa
            WHERE vnt.sys_pk = @doc
            "
            ref doc:dbr.rec(db,sql,params)

            aplicados = dbr.num(db,"SELECT COUNT(apl.sys_pk) FROM dcxc cxc INNER JOIN aplcxc apl ON cxc.sys_pk = apl.aplicadoa WHERE cxc.iventa = @iventa;",doc)
            if aplicados > 0 { do rise_error(500,"No es posible cancelar la factura porque tiene pagos relacionados.") }
        }
        else if _entity_id == "cxc" {
            sql = "
            SELECT cxc.sys_pk AS idcxc, cfd.sys_pk AS icfd, cxc.referencia, IFNULL(cfd.uf_foliosat,'') AS uf_foliosat
            FROM dcxc cxc
                LEFT JOIN ut_cfd cfd ON cxc.sys_pk = cfd.uf_idcxc
            WHERE cxc.sys_pk = @doc
            "
            ref doc:dbr.rec(db,sql,params)
        }

        if isnull(doc) { do rise_error(500,"No fue posible recuperar el documento.") }
        if @@(doc,"$uf_foliosat") == "" { do rise_error(500,"El documento aun no ha sido timbrado.") }

        do dbr.begin(db)

        sql_unlink_cfdi = "
        UPDATE ut_cfd SET
            sys_info = COALESCE(CONCAT('uf_iventa:',uf_iventa),CONCAT('uf_idcxc:',uf_idcxc)),
            uf_canceladosat=1,
            uf_ackcancelacion_sat='1',
            uf_iventa=NULL,
            uf_idcxc=NULL
        WHERE sys_pk = @icfd
        "
        if not(dbr.execute(db,sql_unlink_cfdi,doc)) { do rise_error(500,"No fue posible establecer la cancelación.") }

        new header { @"Content-Type": "application/json; charset=UTF-8" }
        new payload
        {
            @"ctaTimb": "#" // Autorizar por cuenta de timbrado.
            @"cti": field.str(emisor,"cti") // Cuenta de timbrado.
            @"pwd": field.str(emisor,"pwd") // Contraseña de la cuenta de timbrado.
            @"uuid": @@(doc,"$uf_foliosat") // UUID del CFDI.
            @"tipo": "cfdi" // Tipo de documento solicitado: cfdi-CFDI o cr-Constancia de retención.
            @"motivo": cve_motivo // Clave del motivo de cancelación del SAT.
            @"frel": rel_uuid // UUID del CFDI relacionado, en caso de que el motivo sea'01'.
        }

        ref response = from.json(http.request(@svc_fdsk_cancelar,"POST",header,to.json(payload)))
        if not(@@(response,"#success")) { do rise_error(500,@@(response,"$message")) }
        @url_redir = ifstr(field.exist(params,"---from_url_e"), url_dcode(@@(params,"$---from_url_e")), @CFD_EMISION)

        do dbr.commit(db)

        exception{ do catch(db,params,data) }
    }

    cfdi.download::&db,&params
    {
        //#region download()
        ref response = emision.descargar(db,@@(params,"$uuid"),"ziplnk")
        return @@(response,"&data")
    }

    saveResponse::&db,&response,comprobante,rfc_emisor,cfdi_id
    {
        //#region saveResponse()
        if not(parse.bool(@@(response,"$success"))) {
            message = @@(response,"$message")

            do emision.saveLog(db, @false, rfc_emisor, cfdi_id, comprobante, message)
            do rise_error(500,message)
        }
        else {
            do emision.saveLog(db, @true, rfc_emisor, @@(response,"$data/uuid"), @@(response,"$data/xml"), "")
            do emision.removeLog(db, rfc_emisor, cfdi_id)
        }
    }

    saveLog::&db,success,rfc_emisor,cfdi_id,cfdi,log
    {
        //#region saveLog()
        new parameters
        {
            @"emisor": rfc_emisor
        }

        success_cfdi_path = dbr.vars.getd(db,"mxcfdi_success_cfdi_path",@default_scfdi_path)
        failure_cfdi_path = dbr.vars.getd(db,"mxcfdi_failure_cfdi_path",@default_fcfdi_path)

        log_path = ifstr(success, success_cfdi_path, failure_cfdi_path)
        log_path = replace_path_macros(log_path,parameters)
        do dir.ensure(log_path)

        file_path = path.concat(log_path,cfdi_id)
        do file.wtext(file_path+".xml",from.base64(cfdi))
        if not(success) { do file.wtext(file_path+".txt",log) }
    }

    removeLog::&db,rfc_emisor,cfdi_id
    {
        //#region removeLog()
        new parameters
        {
            @"emisor": rfc_emisor
        }

        failure_cfdi_path = dbr.vars.getd(db,"mxcfdi_failure_cfdi_path",@default_fcfdi_path)
        
        log_path = replace_path_macros(failure_cfdi_path,parameters)
        file_path = path.concat(log_path,cfdi_id)

        if file.exists(file_path+".xml") { do file.delete(file_path+".xml") }
        if file.exists(file_path+".txt") { do file.delete(file_path+".txt") }
    }

    catch::&db,&params,&data
    {
        //#region catch()
        do errordet(@error_det)
        if isnull(data){ ref data:record.create() }
        if dbr.in_transaction(db){ do dbr.rollback(db) }

        code = last_error_code()
        error = last_error()

        ref FormData = record.copy(data,"*")
        do record.clear(data)
        data<"form*"> : FormData

        if isset("@@_action_context"){ do dbr.apps.action.log() }
        do emision.prepareView(db,params,data)
        do rise_error(code,error)
    }
}