#include "dkli.dkh"
#!
module "POS Services"
{
    #include "functions.dkh"
    #include "serialize.dkh"
    #include "webcl.dkh"
    #include "dbr.dkh"
    #include "dbr.vars.dkl"
    #include "dbr.folios.dkl"
    #include "website.dkl"
    #include "mxcfdi/_lib/config.dk"
    #include "mxcfdi/_lib/lib.dk"

    go api_base_service(method:method, params:params, payload:postData, response:response)
    {
        if method != "POST" { do rise_error(511,"Método proporcionado no admitido") }
        ref db = get_db()
        // do rise_error(0,to.json(@@(@http_context,"&session/idp")))

        switch @@(postData,"$operacion")
        {
            case "obtener_venta"
            {
                response<"data"> : pos.ticket.obtener(db,postData)
                break
            }
            case "venta_facturada"
            {
                response<"data*"> : pos.ticket.facturar(db,postData)
                break
            }
            default { do rise_error(500,"Operación no implementada.") }
        }

        if isset("@open_connection"){
            if @open_connection { do dbr.close(db) }
        }

        exception
        {
            do errordet(@false)
            if isset("@open_connection"){
                if dbr.in_transaction(db){ do dbr.rollback(db) }
                if @open_connection { do dbr.close(db) }
            }

            code = last_error_code()
            error = last_error()

            using response
            {
                @"success": @false
                @"message": error
            }
        }
    }
}